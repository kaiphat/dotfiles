config-file = ./fonts/maple
config-file = ./themes/rose_pine_light

custom-shader-animation = true
custom-shader = ./shaders/warp_cursor.glsl

font-thicken = false
fullscreen = true

macos-non-native-fullscreen = false
macos-option-as-alt = true

cursor-style-blink = false
cursor-style = block
cursor-color = #FFB929
#cursor-text = #011115
#cursor-color = #eD84a7
cursor-text = #112233
# cursor-color = #f4b8e4
# cursor-text = #000000

adjust-cursor-height = 100%
adjust-cursor-thickness = 1

scrollbar = never
shell-integration-features = no-cursor,no-title

window-vsync = true
window-padding-x = 10
window-padding-y = 3
window-padding-balance = true

confirm-close-surface = false
mouse-hide-while-typing = true

# background-opacity = 1
# background-image-opacity = 0.7
# background-blur = 10
# background-image = ~/Downloads/kate-chikina-HAxoGmx2AYw-unsplash.jpg
# background-image-fit = cover

link-url = true
shell-integration = none
initial-command = /bin/bash -l -c  "/opt/homebrew/bin/nu -l -i"

auto-update-channel = tip

keybind = cmd+shift+,=reload_config
