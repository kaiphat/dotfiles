config-file = ./fonts/mononoki
config-file = ./themes/tokyo_dark
custom-shader-animation = false
#custom-shader = ./shaders/zoom.glsl

font-thicken = true
fullscreen = true

macos-non-native-fullscreen = false
macos-option-as-alt = true

cursor-style-blink = false
cursor-style = block
#cursor-color = #FFB929
#cursor-text = #011115
#cursor-color = #5DE4C7
#cursor-text = #112233
cursor-color = #f4b8e4
cursor-text = #000000

adjust-cursor-height = 100%
adjust-cursor-thickness = 1

scrollbar = never
shell-integration-features = no-cursor,no-title

window-vsync = true
window-padding-x = 6
window-padding-y = 2
window-padding-balance = true

confirm-close-surface = false
mouse-hide-while-typing = true

background-opacity = 1
background-blur = 10
#background-image = "~/Downloads/2025-05-16 14.02.10.jpg"

link-url = true
shell-integration = none
initial-command = /bin/bash -l -c  "/opt/homebrew/bin/nu -l -i"

auto-update-channel = tip

keybind = cmd+shift+,=reload_config
